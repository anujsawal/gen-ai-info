# ─── LLM: Groq (primary — free at console.groq.com) ─────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── LLM: Gemini (fallback when Groq hits rate limit — free at aistudio.google.com) ─
GEMINI_API_KEY=your_gemini_api_key_here
# ─── Database ─────────────────────────────────────────────────────────────────
# For local Docker dev (default):
DATABASE_URL=postgresql+asyncpg://genai:genai_pass@localhost:5432/genai_info
# For Supabase (production):
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASS@db.xxx.supabase.co:5432/postgres

# ─── LangSmith (smith.langchain.com) ─────────────────────────────────────────
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=genai-info-pipeline
LANGCHAIN_TRACING_V2=true

# ─── WhatsApp: Twilio Sandbox (free at twilio.com) ───────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ─── Newsletter Schedule ──────────────────────────────────────────────────────
# Cron syntax: minute hour day_of_month month day_of_week
NEWSLETTER_CRON_SCHEDULE=0 8 * * 1

# ─── App Settings ─────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_me_to_random_32_char_string
PDF_OUTPUT_DIR=./pdfs
LOG_LEVEL=INFO

# ─── Embedding Model ─────────────────────────────────────────────────────────
# Local sentence-transformers model (downloads automatically on first run)
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1
EMBEDDING_DIMENSION=768

# ─── LLM Models (Groq) ───────────────────────────────────────────────────────
LLM_LARGE=llama-3.3-70b-versatile
LLM_FAST=llama-3.1-8b-instant

# ─── Clustering ──────────────────────────────────────────────────────────────
CLUSTER_MIN_SIZE=2
CLUSTER_MAX_ARTICLES_PER_RUN=100

# ─── Hallucination Gate ──────────────────────────────────────────────────────
FAITHFULNESS_THRESHOLD=0.7
MAX_QA_RETRIES=2
